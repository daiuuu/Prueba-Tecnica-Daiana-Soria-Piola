# =============================================================================
# ASISTENTE AUTOMATIZADO DE SOPORTE TÉCNICO
# Copiar este archivo como .env y completar los valores
# cp .env.example .env
# =============================================================================


# =============================================================================
# OPENAI — REQUERIDO PARA PRODUCCIÓN
# =============================================================================

OPENAI_API_KEY=sk-clave-de-ejemplo

# Modelo para generar respuestas: gpt-3.5-turbo (más económico)
OPENAI_MODEL=gpt-3.5-turbo

# Modelo para generar embeddings
EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# CHROMADB — Base de datos vectorial
# =============================================================================

# Ruta al directorio donde se guarda la base de datos vectorial
CHROMA_DIR=../data/chroma_db

# Nombre de la colección dentro de ChromaDB
CHROMA_COLLECTION=soporte_docs


# =============================================================================
# DOCUMENTOS — Ingesta
# =============================================================================

# Ruta al directorio con los documentos fuente
DOCS_DIR=../docs

# Tamaño máximo de cada chunk en caracteres
CHUNK_SIZE=400

# Solapamiento entre chunks consecutivos en caracteres
CHUNK_OVERLAP=80


# =============================================================================
# BÚSQUEDA — Parámetros de recuperación
# =============================================================================

# Cantidad de fragmentos a recuperar por consulta (1-10)
TOP_K=4

# Score mínimo de relevancia para incluir un fragmento (0.0 a 1.0)
# Valores más altos = más estricto, puede devolver menos resultados
# Valores más bajos = más permisivo, puede incluir resultados poco relevantes
MIN_SCORE=0.30


# =============================================================================
# SERVIDOR — FastAPI
# =============================================================================

# Puerto donde corre la API
PORT=8000

# Cantidad máxima de tokens en la respuesta del LLM
MAX_TOKENS=800

# Temperatura del modelo (0.0 = determinista, 1.0 = creativo)
# Para soporte técnico se recomienda valor bajo
TEMPERATURE=0.2


# =============================================================================
# LOGGING
# =============================================================================

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO