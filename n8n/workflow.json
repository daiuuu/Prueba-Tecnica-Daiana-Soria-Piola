    {
      "parameters": {
        "jsCode": "// Validar que el body tenga el campo 'pregunta'\nconst body = $input.first().json.body || $input.first().json;\nconst pregunta = body.pregunta || body.question || body.mensaje || '';\n\nif (!pregunta || pregunta.trim().length === 0) {\n  return [{\n    json: {\n      valido: false,\n      error: 'El campo pregunta es requerido y no puede estar vacío.',\n      pregunta: ''\n    }\n  }];\n}\n\nif (pregunta.trim().length < 3) {\n  return [{\n    json: {\n      valido: false,\n      error: 'La pregunta es demasiado corta.',\n      pregunta: pregunta.trim()\n    }\n  }];\n}\n\nif (pregunta.trim().length > 2000) {\n  return [{\n    json: {\n      valido: false,\n      error: 'La pregunta supera el límite de 2000 caracteres.',\n      pregunta: pregunta.trim().substring(0, 50) + '...'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    valido: true,\n    error: '',\n    pregunta: pregunta.trim(),\n    top_k: body.top_k || 4\n  }\n}];"
      },
      "id": "validar-input",
