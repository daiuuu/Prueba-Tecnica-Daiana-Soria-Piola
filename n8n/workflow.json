      "id": "llamar-api-python",
      "name": "Llamar API Python",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 200]
    },
    {
      "parameters": {
        "jsCode": "// Procesar respuesta de app.py\nconst respuesta = $input.first().json;\nconst statusCode = respuesta.statusCode || 200;\nconst body = respuesta.body || respuesta;\n\n// Si la API devolvió error HTTP\nif (statusCode >= 400) {\n  return [{\n    json: {\n      exito: false,\n      respuesta: null,\n      mensaje_error: body.error || 'Error en el servicio de soporte.',\n      fuentes: [],\n      tiempo_segundos: 0,\n      status_code: statusCode\n    }\n  }];\n}\n\n// Respuesta exitosa\nconst metadata = body.metadata || {};\n\nreturn [{\n  json: {\n    exito: body.success === true,\n    respuesta: body.respuesta || null,\n    mensaje_error: body.error || null,\n    fuentes: metadata.fuentes || [],\n    fragmentos_usados: metadata.fragmentos_usados || 0,\n    encontrado_en_docs: metadata.encontrado_en_docs || false,\n    tiempo_segundos: metadata.tiempo_segundos || 0,\n    modelo: metadata.modelo || '',\n    status_code: statusCode\n  }\n}];"
      },
